# Copy this to .env and fill in your values

# ── Kalshi API credentials ────────────────────────────────────────────────────
# Get these from: Kalshi → Account & Security → API Keys → Create Key
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.key

# ── Trading settings ──────────────────────────────────────────────────────────
DRY_RUN=true           # Set to false to place real orders
BANKROLL=100.00        # Your available bankroll in USD
MIN_EDGE=0.07          # Minimum edge (in dollars) to trigger a bet
